{
  "name": "@haakco/custd-sdk",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "10.33.2"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./browser-script": {
      "types": "./dist/browser-script.d.ts",
      "import": "./dist/browser-script.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "pnpm run build",
    "test": "vitest run --exclude dist/**",
    "smoke:dev": "pnpm run build && node scripts/smoke-dev.js"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
