{
  "name": "@haakco/custd-sdk",
  "version": "1.5.9",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "10.33.2"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./browser-script": {
      "types": "./dist/browser-script.d.ts",
      "import": "./dist/browser-script.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://verdaccio.k8.haak.co/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run src",
    "smoke:dev": "pnpm run build && node scripts/smoke-dev.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
