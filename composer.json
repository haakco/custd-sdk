{
  "name": "haakco/custd-sdk",
  "description": "Custd ingestion PHP SDK (pure PHP)",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "HaakCo\\Custd\\": "sdk-php/src/"
    },
    "files": [
      "sdk-php/bootstrap/aliases.php"
    ]
  },
  "require": {
    "php": ">=8.3",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HaakCo\\Custd\\Tests\\": "sdk-php/tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "smoke:dev": "php sdk-php/scripts/smoke-dev.php"
  }
}
