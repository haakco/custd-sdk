{
  "name": "haakco/custd-sdk",
  "description": "custd ingestion SDK (minimal Phase 1)",
  "type": "library",
  "license": "MIT",
  "version": "1.3.0",
  "autoload": {
    "psr-4": {
      "HaakCo\\Custd\\": "src/"
    },
    "files": [
      "bootstrap/aliases.php"
    ]
  },
  "require": {
    "php": ">=8.3",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^2.2",
    "laravel/pint": "^1.29"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HaakCo\\Custd\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "format": "pint",
    "format-check": "pint --test",
    "smoke:dev": "php scripts/smoke-dev.php"
  }
}
