{
  "name": "haakco/custd-sdk",
  "description": "custd ingestion SDK (minimal Phase 1)",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "HaakCo\\Custd\\": "src/"
    },
    "files": [
      "src/CustdClient.php"
    ]
  },
  "require": {
    "php": ">=8.4.1",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1"
  },
  "autoload-dev": {
    "psr-4": {
      "HaakCo\\Custd\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "smoke:dev": "php scripts/smoke-dev.php"
  }
}
