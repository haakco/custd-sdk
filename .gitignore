.DS_Store
node_modules/
vendor/

# Local env + Infisical secret cache (loaded by .mise.toml; never commit secrets).
.env
.env.infisical.local
.env.infisical.local.lock

# Framework subtree packages resolve haakco/custd-sdk via a local path repo, so
# their lock files pin transient dev state. They are libraries — CI installs the
# latest matching deps, so the locks are regenerated, not committed.
/laravel-package/composer.lock
/wordpress-plugin/composer.lock
dist/
!/sdk-js/dist/
!/sdk-js/dist/**
coverage/
.phpunit.result.cache
.pytest_cache/
__pycache__/
*.pyc
.venv/
*.egg-info/
tmp/
*.log
